# conjure local configuration template
# Copy to .env for local development. Keep real secrets out of Git.

# Anthropic / Claude
ANTHROPIC_API_KEY=
CONJURE_DEMO_MODE=true
CONJURE_ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_PRIMARY_MODEL=
ANTHROPIC_SECONDARY_MODEL=
ANTHROPIC_MEMORY_MODEL=claude-haiku-4-5

# Redis datastore, memory, sandbox cache, and job streams
REDIS_URL=redis://localhost:6379/0
CONJURE_REDIS_URL=redis://localhost:6379/0
REDIS_NAMESPACE=conjure:dev
SANDBOX_RESULT_TTL_SECONDS=86400
CONJURE_SANDBOX_RESULT_TTL_SECONDS=86400
CONJURE_REDIS_FALLBACK=true
CONJURE_MEMORY_DEMO=true

# Browserbase sandbox infrastructure
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_SESSION_REGION=
BROWSERBASE_REPLAY_ENABLED=true

# Simular autonomous tester / red-team driver
SIMULAR_API_KEY=
SIMULAR_BASE_URL=
SIMULAR_AGENT_MODEL=

# Sentry observability
SENTRY_DSN=
SENTRY_SANDBOX_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# Backend service
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_URL=http://127.0.0.1:8000
BACKEND_WS_URL=ws://127.0.0.1:8000/ws
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
GENERATED_CODE_ROOT=demo_code
SANDBOX_MAX_HEAL_ITERATIONS=3

# Chrome extension build-time config exposed through Vite.
# Values prefixed with VITE_ are bundled into the extension.
VITE_BACKEND_URL=http://127.0.0.1:8000
VITE_BACKEND_WS_URL=ws://127.0.0.1:8000/ws
VITE_CONJURE_WS_BASE_URL=ws://127.0.0.1:8000
VITE_CONJURE_PROJECT_ID=local-demo
VITE_EXTENSION_ENV=development
VITE_SENTRY_DSN=
VITE_ENABLE_SANDBOX_UI=true

# Optional smoke-test target. Leave blank unless a backend is already running.
CONJURE_SMOKE_BACKEND_URL=
